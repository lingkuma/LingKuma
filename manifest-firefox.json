{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "icons": {
    "128": "src/icons/icon128.png",
    "48": "src/icons/icon48.png",
    "32": "src/icons/icon32.png",
    "16": "src/icons/icon16.png"
  },
  "permissions": [
    "activeTab",
    "tts",
    "storage",
    "tabs",
    "offscreen",
    "downloads",
    "sidePanel",
    "clipboardRead",
    "contextMenus",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/utils/highlight_floating_button.js",
        "src/service/a1_loadKnowWords.js",
        "src/service/a2_hightlight.js"
      ],
      "css": ["content.css"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "./src/popup/popup.html"
  },
  "side_panel": {
    "default_path": "src/sidebar/sidebar.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/options/images/*",
        "src/service/jp/dict/*",
        "src/service/image/pattern.png",
        "src/service/image/pattern2.png",
        "src/service/image/pattern3.png",
        "src/service/image/tg/*.svg",
        "src/service/image/tg_png/*.jpg",
        "src/service/image/lottie/*.tgs",
        "src/service/image/lottie/tgs-balloon.html",
        "src/service/image/lottie/tgs-balloon.js",
        "src/utils/liquid-glass.js",
        "src/utils/tgs-player.min.js",
        "src/service/videos/kawai.mp4",
        "src/popup/popup.html",
        "src/player/offscreen.html",
        "src/player/offscreen.js",
        "src/plugin/orion_tts.js",
        "src/plugin/youtubeCaptionInjected.js",
        "src/sidebar/sidebar.html",
        "src/utils/liquid-glass.js",
        "src/fonts/LXGWWenKaiGBLite-Regular.ttf",
        "src/fonts/Fanwood.otf",
        "src/fonts/Fanwood_Bold.otf",
        "src/fonts/Fanwood_Italic.otf",
        "src/icons/*" 
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox@lingkuma.org",
      "strict_min_version": "140.0"
    }
  }
}
